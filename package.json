{
  "name": "vitest-pdf-snapshot",
  "type": "module",
  "version": "0.0.2-0",
  "packageManager": "pnpm@10.33.0",
  "description": "A custom Vitest matcher for PDF visual regression testing with snapshot support",
  "author": "dapotatoman",
  "license": "MIT",
  "homepage": "https://github.com/dapotatoman/vitest-pdf-snapshot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dapotatoman/vitest-pdf-snapshot.git"
  },
  "bugs": {
    "url": "https://github.com/DaPotatoMan/vitest-pdf-snapshot/issues"
  },
  "exports": {
    ".": {
      "types": "./src/types.d.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vp pack",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "release": "npm run test -- --run && changelogen --release --prepatch && npm publish && git push --follow-tags"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/types.d.ts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "peerDependencies": {
    "vitest": "^3.0.0 || ^4.0.0"
  },
  "dependencies": {
    "glob": "^13.0.0",
    "pdf-visual-diff": "^0.15.2",
    "sanitize-filename": "^1.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@types/node": "^25.5.2",
    "@typescript/native-preview": "7.0.0-dev.20260404.1",
    "bumpp": "^11.0.1",
    "changelogen": "^0.6.2",
    "eslint": "^10.1.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.15"
  }
}
